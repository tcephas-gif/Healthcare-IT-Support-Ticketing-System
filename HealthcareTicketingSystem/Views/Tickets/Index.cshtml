@model IEnumerable<HealthcareTicketingSystem.Models.Ticket>

@{
    ViewData["Title"] = "Healthcare Support Tickets";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold">Healthcare Support Tickets</h1>
        <p class="text-muted">
            Track IT support requests for healthcare systems and services.
        </p>
    </div>

        <a asp-action="Create" class="btn btn-primary btn-lg create-ticket-btn">
            <i class="bi bi-plus-circle me-2"></i>
            Create Ticket
        </a>
   
</div>

<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <a asp-controller="Reports" asp-action="Index" class="text-decoration-none">
            <div class="card dashboard-card text-white bg-primary">
                <div class="card-body text-center">
                    <h5 class="fw-semibold">Total Tickets</h5>
                    <h2>@ViewBag.TotalTickets</h2>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-3 mb-3">
        <a asp-controller="Reports" asp-action="Index" asp-fragment="status-chart" class="text-decoration-none">
            <div class="card dashboard-card text-white bg-success">
                <div class="card-body text-center">
                    <h5 class="fw-semibold">Open Tickets</h5>
                    <h2>@ViewBag.OpenTickets</h2>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-3 mb-3">
        <a asp-controller="Reports" asp-action="Index" asp-fragment="status-chart" class="text-decoration-none">
            <div class="card dashboard-card text-white bg-warning">
                <div class="card-body text-center">
                    <h5 class="fw-semibold">In Progress</h5>
                    <h2>@ViewBag.InProgressTickets</h2>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-3 mb-3">
        <a asp-controller="Reports" asp-action="Index" asp-fragment="priority-chart" class="text-decoration-none">
            <div class="card dashboard-card text-white bg-danger">
                <div class="card-body text-center">
                    <h5 class="fw-semibold">High Priority</h5>
                    <h2>@ViewBag.HighPriorityTickets</h2>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-12 mb-3">
        <a asp-controller="Reports" asp-action="Index" asp-fragment="category-chart" class="text-decoration-none">
            <div class="card dashboard-card text-white bg-info">
                <div class="card-body text-center">
                    <h5 class="fw-semibold">Top Category</h5>
                    <h2>@(ViewBag.TopCategory ?? "None")</h2>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-12">
        <a asp-controller="Reports" asp-action="Index" class="text-decoration-none">
            <div class="card dashboard-card text-white bg-secondary">
                <div class="card-body text-center">
                    <h5 class="fw-semibold">Top Assigned Technician</h5>
                    <h2>@(ViewBag.TopTechnician ?? "None")</h2>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="card report-card shadow-sm mb-4">
    <div class="card-header bg-dark text-white py-3">
        <h5 class="mb-0 fw-semibold">Search and Filter Tickets</h5>
    </div>

    <div class="card-body">
        <form asp-action="Index"
              method="get"
              class="row g-3 align-items-center"
              autocomplete="off">

            <div class="col-md-3">
                <input type="search"
                       name="searchString"
                       value="@ViewBag.SearchString"
                       class="form-control"
                       placeholder="Search tickets..."
                       autocomplete="new-password"
                       spellcheck="false" />
            </div>

            <div class="col-md-2">
                <input type="search"
                       name="statusFilter"
                       value="@ViewBag.StatusFilter"
                       class="form-control"
                       placeholder="Status"
                       autocomplete="new-password"
                       spellcheck="false" />
            </div>

            <div class="col-md-2">
                <input type="search"
                       name="priorityFilter"
                       value="@ViewBag.PriorityFilter"
                       class="form-control"
                       placeholder="Priority"
                       autocomplete="new-password"
                       spellcheck="false" />
            </div>

            <div class="col-md-3">
                <input type="search"
                       name="categoryFilter"
                       value="@ViewBag.CategoryFilter"
                       class="form-control"
                       placeholder="Category"
                       autocomplete="new-password"
                       spellcheck="false" />
            </div>

            <div class="col-md-2 d-grid gap-2">
                <button class="btn btn-dark" type="submit">
                    Filter
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    Clear
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card report-card shadow-sm mb-4">
    <div class="card-header bg-dark text-white py-3">
        <h5 class="mb-0 fw-semibold">Ticket Management</h5>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Department</th>
                        <th>Category</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Reported By</th>
                        <th>Assigned To</th>
                        <th>Created Date</th>
                        <th>Days Open</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        var daysOpen = (DateTime.Now - item.CreatedDate).Days;

                        <tr>
                            <td>@item.Title</td>
                            <td>@item.Department</td>
                            <td>@item.Category</td>

                            <td>
                                @if (item.Priority == "Critical")
                                {
                                    <span class="badge bg-danger">Critical</span>
                                }
                                else if (item.Priority == "High")
                                {
                                    <span class="badge bg-warning text-dark">High</span>
                                }
                                else if (item.Priority == "Medium")
                                {
                                    <span class="badge bg-primary">Medium</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Low</span>
                                }
                            </td>

                            <td>
                                @if (item.Status == "Open")
                                {
                                    <span class="badge bg-success">Open</span>
                                }
                                else if (item.Status == "In Progress")
                                {
                                    <span class="badge bg-warning text-dark">In Progress</span>
                                }
                                else if (item.Status == "Resolved")
                                {
                                    <span class="badge bg-primary">Resolved</span>
                                }
                                else if (item.Status == "Closed")
                                {
                                    <span class="badge bg-dark">Closed</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Status</span>
                                }
                            </td>

                            <td>@item.ReportedBy</td>
                            <td>@item.AssignedTo</td>
                            <td>@item.CreatedDate.ToString("MM/dd/yyyy")</td>

                            <td>
                                @if (daysOpen == 0)
                                {
                                    <span class="badge bg-success">Today</span>
                                }
                                else if (daysOpen <= 3)
                                {
                                    <span class="badge bg-info">@daysOpen day(s)</span>
                                }
                                else if (daysOpen <= 7)
                                {
                                    <span class="badge bg-warning text-dark">@daysOpen days</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">@daysOpen days</span>
                                }
                            </td>

                            <td>
                                <div class="d-grid gap-1">
                                    <a asp-action="Edit" asp-route-id="@item.TicketId" class="btn btn-sm btn-outline-primary">
                                        Edit
                                    </a>

                                    <a asp-action="Details" asp-route-id="@item.TicketId" class="btn btn-sm btn-outline-secondary">
                                        Details
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.TicketId" class="btn btn-sm btn-outline-danger">
                                        Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>