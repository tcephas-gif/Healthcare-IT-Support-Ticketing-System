@model HealthcareTicketingSystem.Models.Ticket

@{
    ViewData["Title"] = "Delete Ticket";
}

<h1>Delete Ticket</h1>

<h3>Are you sure you want to delete this ticket?</h3>

<div>
    <hr />

    <dl class="row">
        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.Title</dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Description</dd>

        <dt class="col-sm-2">Department</dt>
        <dd class="col-sm-10">@Model.Department</dd>

        <dt class="col-sm-2">Priority</dt>
        <dd class="col-sm-10">@Model.Priority</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.Status</dd>

        <dt class="col-sm-2">Assigned To</dt>
        <dd class="col-sm-10">@Model.AssignedTo</dd>

        <dt class="col-sm-2">Created Date</dt>
        <dd class="col-sm-10">@Model.CreatedDate</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="TicketId" />

        <input type="submit" value="Delete Ticket" class="btn btn-danger" />

        <a asp-action="Index" class="btn btn-secondary ms-2">
            Back to List
        </a>
    </form>
</div>